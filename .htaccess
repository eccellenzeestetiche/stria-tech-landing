DirectoryIndex index.html

RewriteEngine On
RewriteRule ^stria-tech/?$ /stria-tech/index.html [R=301,L]

# Disabilita cache per HTML e CSS — aggiornamento immediato dopo ogni deploy
<FilesMatch "\.(html|css)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires 0
</FilesMatch>
